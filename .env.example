# =============================================================================
# Anime Shop — Environment Configuration Template
# Copy file này thành .env (local) hoặc .env.production (production)
# KHÔNG commit .env hay .env.production vào git
# Tạo APP_KEY: php artisan key:generate --show
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Anime Shop"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file

# Tăng lên 14 trên production để tăng bảo mật password hash
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging — production nên dùng error để tránh log nhạy cảm
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# -----------------------------------------------------------------------------
# Database (MySQL)
# Docker local: DB_HOST=mysql | Server thật: DB_HOST=127.0.0.1 hoặc IP
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=anime_shop
DB_USERNAME=anime_shop
DB_PASSWORD=
DB_ROOT_PASSWORD=

# -----------------------------------------------------------------------------
# Session
# production: SESSION_DRIVER=redis hoặc database
# SESSION_ENCRYPT=true bảo vệ session data khỏi bị đọc trực tiếp từ storage
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

# -----------------------------------------------------------------------------
# Cache & Queue
# production: CACHE_STORE=redis | QUEUE_CONNECTION=redis (nếu có Redis)
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# -----------------------------------------------------------------------------
# Redis (dùng cho cache/session/queue khi scale)
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail
# production: đổi sang smtp (Mailgun, SES, Postmark...)
# Ví dụ Mailgun: MAIL_MAILER=mailgun, thêm MAILGUN_DOMAIN, MAILGUN_SECRET
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# S3-compatible Storage — ảnh sản phẩm upload qua Filament
#
# AWS S3           : để AWS_ENDPOINT trống, AWS_USE_PATH_STYLE_ENDPOINT=false
# DigitalOcean Spaces: AWS_ENDPOINT=https://REGION.digitaloceanspaces.com
#                     AWS_DEFAULT_REGION=sgp1 (hoặc region DO của bạn)
# Cloudflare R2    : AWS_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
#                     AWS_USE_PATH_STYLE_ENDPOINT=true
#
# Đổi FILESYSTEM_DISK=s3 khi deploy production
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Filament Admin
# FILAMENT_FILESYSTEM_DISK: disk mặc định cho file upload trong Filament
# Nếu để trống, Filament dùng FILESYSTEM_DISK ở trên
# -----------------------------------------------------------------------------
FILAMENT_FILESYSTEM_DISK=public

# -----------------------------------------------------------------------------
# Thanh toán VietQR — chuyển khoản ngân hàng
# PAYMENT_BANK_ID: mã ngân hàng (VCB, TCB, BIDV, MB, ACB...)
# -----------------------------------------------------------------------------
PAYMENT_BANK_ID=VCB
PAYMENT_ACCOUNT_NO=1014996340
PAYMENT_ACCOUNT_NAME="NGUYEN MINH DUC"

# -----------------------------------------------------------------------------
# reCAPTCHA v3 — chống spam checkout
# Tạo key tại: https://www.google.com/recaptcha/admin/create
# Chọn loại: reCAPTCHA v3, domain: shop.ducdev.work (và localhost)
# -----------------------------------------------------------------------------
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# Vite (frontend build)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_RECAPTCHA_SITE_KEY="${RECAPTCHA_SITE_KEY}"
